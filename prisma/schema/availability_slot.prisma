

model AvailabilitySlot {
    id String @id @default(uuid())

    dayOfWeek Int @db.SmallInt() @map("day_of_week")
    startTime DateTime @db.Time() @map("start_time")
    endTime DateTime @db.Time() @map("end_time")

    technicianId String @map("technician_id")
    technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("availability_slots")
}