

model Review {
    id String @id @default(uuid())
    rating Int @db.SmallInt()
    comment String?

    bookingId String @unique @map("booking_id")
    booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    createdAt DateTime @db.Timestamptz(0) @default(now()) @map("created_at")
    updatedAt DateTime @db.Timestamptz(0) @updatedAt @map("updated_at")

    @@map("reviews")
}