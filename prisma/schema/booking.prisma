

model Booking {
    id String @id @default(uuid())

    startTime DateTime @db.Timestamptz(0) @map("start_time")
    endTime DateTime @db.Timestamptz(0) @map("end_time")
    
    status BookingStatus @default(REQUESTED)
    amount Decimal @db.Decimal(8, 2)

    customerId String @map("customer_id")
    customer User @relation(fields: [customerId], references: [id])

    technicianId String @map("technician_id")
    technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

    serviceId String @map("service_id")
    service Service @relation(fields: [serviceId], references: [id])

    stripeCheckoutSessionId String? @map("stripe_checkout_session_id")
    stripePaymentIntentId String? @map("stripe_payment_intent_id")

    createdAt DateTime @db.Timestamptz(0) @default(now()) @map("created_at")
    updatedAt DateTime @db.Timestamptz(0) @updatedAt @map("updated_at")

    review Review?
    payment Payment?

    @@map("bookings")
    @@index([technicianId, startTime, endTime])
}